# Copy this file for each new site clone:
#   cp .env.local.example .env.local
#
# Never commit .env.local (gitignored). reCAPTCHA details: docs/recaptcha.md
#
# Agency setup: ONE Google Cloud project for all client sites.
#   - RECAPTCHA_PROJECT_ID + RECAPTCHA_API_KEY_SECRET → same on every clone
#   - NEXT_PUBLIC_RECAPTCHA_SITE_KEY → per client (or same if one key lists all domains)

# --- reCAPTCHA Enterprise (optional — leave blank to disable verification) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_PROJECT_ID=
# Secret key (6Le...) OR Cloud API key (AIzaSy...) — usually same across all clones
RECAPTCHA_API_KEY_SECRET=

# --- Future integrations ---
# LIFESPRING_HUB_API_URL=
# LIFESPRING_HUB_API_KEY=
# RESEND_API_KEY=
